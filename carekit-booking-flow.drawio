        <!-- Refund types -->
        <mxCell id="refund-box" value="&lt;b&gt;Refund Types:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• full — 100% refund&lt;br&gt;• partial — custom amount (validated)&lt;br&gt;• none — no refund&lt;br&gt;suggestedRefundType pre-calculated&lt;br&gt;based on freeCancelBeforeHours&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;" vertex="1" parent="1">
