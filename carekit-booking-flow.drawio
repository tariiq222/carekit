        <!-- Admin Direct & Practitioner Cancel -->
        <mxCell id="admin-direct" value="&lt;b&gt;Admin Direct Cancel&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Any non-terminal → CANCELLED&lt;br&gt;Refund: full / partial / none&lt;br&gt;+ Delete Zoom + Notify + Waitlist&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="1540" width="190" height="70" as="geometry" />
