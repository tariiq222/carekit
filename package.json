{
  "name": "carekit",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/backend",
    "apps/dashboard",
    "apps/admin",
    "apps/website",
    "apps/mobile",
    "packages/shared",
    "packages/api-client",
    "packages/ui"
  ],
  "scripts": {
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=dashboard",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:website": "turbo run dev --filter=website",
    "dev:mobile": "npm run dev --workspace=carekit-mobile",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "openapi:sync": "npm run openapi:export --workspace=backend && npm run openapi:generate --workspace=dashboard",
    "test:report": "py data/test-reports/scripts/generate_html_report.py",
    "test:report:open": "py data/test-reports/scripts/generate_html_report.py && start data/test-reports/output/test-report.html",
    "kiwi:sync-manual": "node scripts/kiwi-sync-manual-qa.mjs --plan"
  },
  "devDependencies": {
    "lru-cache": "^11.3.3",
    "react-test-renderer": "^19.2.4",
    "turbo": "^2"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "minipass": "^7.1.3"
  }
}
