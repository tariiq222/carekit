# Database (Docker mapped port: 5999)
DATABASE_URL=postgresql://carekit:carekit_dev_password@localhost:5999/carekit_dev

# Redis (Docker mapped port: 5380)
REDIS_URL=redis://localhost:5380

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production-32c
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-x
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=5200
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=carekit

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASSWORD=your-mail-password

# OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-key

# Moyasar Payments
MOYASAR_API_KEY=sk_test_your-moyasar-key
MOYASAR_WEBHOOK_SECRET=your-webhook-secret

# Server port
PORT=5100

# Backend public URL (used in webhook callback_url)
BACKEND_URL=http://localhost:5100

# Firebase Cloud Messaging (FCM) — push notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Zoom Server-to-Server OAuth (video consultations)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# SMS Notifications (optional — system works without it)
# SMS_PROVIDER: 'unifonic' or 'twilio'
# SMS_API_KEY: Unifonic AppSid OR Twilio "AccountSID:AuthToken"
# SMS_SENDER_ID: Sender name/number registered with your provider
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# Sentry error tracking (optional — app works without it, but production should have it)
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Prometheus metrics endpoint protection (required in production — app will refuse to start without it)
METRICS_TOKEN=your-metrics-secret-token

# CORS — comma-separated list of allowed frontend origins (required in production)
ALLOWED_ORIGINS=https://dashboard.example.com

# Cookie domain for refresh token cookie (e.g. .example.com for subdomain sharing)
COOKIE_DOMAIN=.example.com
