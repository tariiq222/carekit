// ──────────────────────────────────────────────
// Groups (merged from group-sessions + courses)
// ──────────────────────────────────────────────

model Group {
  id                    String              @id @default(uuid())
  practitionerId        String              @map("practitioner_id")

  // Definition
  nameAr                String              @map("name_ar")
  nameEn                String              @map("name_en")
  descriptionAr         String?             @map("description_ar")
  descriptionEn         String?             @map("description_en")
  minParticipants       Int                 @map("min_participants")
  maxParticipants       Int                 @map("max_participants")
  pricePerPersonHalalat Int                 @map("price_per_person_halalat")
  durationMinutes       Int                 @map("duration_minutes")
  paymentDeadlineHours  Int                 @default(48) @map("payment_deadline_hours")

  // Payment type (replaces depositPercent)
  paymentType           GroupPaymentType    @default(FULL_PAYMENT) @map("payment_type")
  depositAmount         Int?                @map("deposit_amount")
  remainingDueDate      DateTime?           @map("remaining_due_date")

  // Scheduling
  schedulingMode        GroupSchedulingMode @map("scheduling_mode")
  startTime             DateTime?           @map("start_time")
  endTime               DateTime?           @map("end_time")
  endDate               DateTime?           @map("end_date")

  // Delivery
  deliveryMode          DeliveryMode        @default(in_person) @map("delivery_mode")
  location              String?
  meetingLink           String?             @map("meeting_link")

  // Status & enrollment
  status                GroupStatus         @default(open) @map("status")
  currentEnrollment     Int                 @default(0) @map("current_enrollment")
  reminderSent          Boolean             @default(false) @map("reminder_sent")

  // Visibility & expiry
  isPublished           Boolean             @default(false) @map("is_published")
  expiresAt             DateTime?           @map("expires_at")

  // Timestamps
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  deletedAt             DateTime?           @map("deleted_at")

  // Relations
  practitioner Practitioner      @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  enrollments  GroupEnrollment[]
  payments     GroupPayment[]
  certificates GroupCertificate[]

  @@index([practitionerId, status])
  @@index([status, expiresAt])
  @@map("groups")
}

model GroupEnrollment {
  id                String                @id @default(uuid())
  groupId           String                @map("group_id")
  patientId         String                @map("patient_id")
  paymentId         String?               @unique @map("payment_id")
  status            GroupEnrollmentStatus @default(registered) @map("status")
  paymentDeadlineAt DateTime?             @map("payment_deadline_at")
  expiredAt         DateTime?             @map("expired_at")
  attended          Boolean               @default(false)
  attendedAt        DateTime?             @map("attended_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  group       Group            @relation(fields: [groupId], references: [id], onDelete: Restrict)
  patient     User             @relation("PatientGroupEnrollments", fields: [patientId], references: [id], onDelete: Restrict)
  payment     Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  groupPayment GroupPayment?
  certificate  GroupCertificate?

  @@unique([groupId, patientId])
  @@index([status, paymentDeadlineAt])
  @@map("group_enrollments")
}

model GroupPayment {
  id               String          @id @default(uuid())
  enrollmentId     String          @unique @map("enrollment_id")
  groupId          String          @map("group_id")
  totalAmount      Int             @map("total_amount")
  paidAmount       Int             @map("paid_amount")
  remainingAmount  Int             @map("remaining_amount")
  method           PaymentMethod
  status           PaymentStatus   @default(pending)
  moyasarPaymentId String?         @unique @map("moyasar_payment_id")
  transactionRef   String?         @map("transaction_ref")
  paidAt           DateTime?       @map("paid_at")
  refundedAt       DateTime?       @map("refunded_at")
  refundReason     String?         @map("refund_reason")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  enrollment GroupEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([groupId])
  @@map("group_payments")
}

model GroupCertificate {
  id           String   @id @default(uuid())
  enrollmentId String   @unique @map("enrollment_id")
  groupId      String   @map("group_id")
  patientId    String   @map("patient_id")
  issuedAt     DateTime @default(now()) @map("issued_at")

  enrollment GroupEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Restrict)
  patient    User            @relation("PatientGroupCertificates", fields: [patientId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([groupId])
  @@map("group_certificates")
}
