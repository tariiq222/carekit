// ──────────────────────────────────────────────
// Bookings & Settings
// ──────────────────────────────────────────────
//
// BOOKING TABLE DESIGN NOTES:
//
// 1. STATE TIMESTAMPS (intentional — not worth a separate table)
//    confirmedAt, checkedInAt, inProgressAt, completedAt, cancelledAt, noShowAt
//    → Each maps to a BookingStatus transition. Kept here for fast single-row reads.
//    → Full history is in BookingStatusLog.
//
// 2. PRICE & DURATION SNAPSHOT (intentional denormalization)
//    bookedPrice, bookedDuration
//    → Captured at booking creation from the pricing fallback chain.
//    → Immutable after creation. Service/practitioner price changes must NOT affect past bookings.
//    → Source of truth for invoicing and refund calculations.
//
// 3. ZOOM FIELDS (candidate for future extraction)
//    zoomMeetingId, zoomJoinUrl, zoomHostUrl
//    → Only populated for BookingType.video_consultation (nullable on all other types).
//    → Future: extract to BookingMeeting table when multi-provider video support is needed.
//    → Migration path: CREATE TABLE booking_meetings (booking_id FK, provider, meeting_id, join_url, host_url)
//
// 4. RECURRING GROUP (intentional)
//    recurringGroupId links sibling bookings. No separate table needed — UUID group key is sufficient.
//    recurringPattern stored per-booking to allow future divergence within a group.
// ──────────────────────────────────────────────

model Booking {
  id                    String            @id @default(uuid())
  patientId             String?           @map("patient_id") // nullable ONLY for onDelete:SetNull — always required at creation
  branchId              String?           @map("branch_id")
  practitionerId        String            @map("practitioner_id")
  serviceId             String            @map("service_id")
  practitionerServiceId String            @map("practitioner_service_id")
  type                  BookingType
  date                  DateTime
  startTime             String            @map("start_time") // "HH:mm"
  endTime               String            @map("end_time") // "HH:mm"
  status                BookingStatus     @default(pending)
  notes                 String?
  // Zoom — video_consultation only. Null on clinic_visit/phone_consultation/walk_in.
  // Future extraction candidate → BookingMeeting table (see file header note #3).
  zoomMeetingId         String?           @map("zoom_meeting_id")
  zoomJoinUrl           String?           @map("zoom_join_url")
  zoomHostUrl           String?           @map("zoom_host_url")
  cancellationReason    String?           @map("cancellation_reason")
  adminNotes            String?           @map("admin_notes")
  cancelledAt           DateTime?         @map("cancelled_at")
  confirmedAt           DateTime?         @map("confirmed_at")
  rescheduledFromId     String?           @unique @map("rescheduled_from_id")
  completedAt           DateTime?         @map("completed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")
  cancelledBy           CancelledBy?      @map("cancelled_by")
  noShowAt              DateTime?         @map("no_show_at")
  checkedInAt           DateTime?         @map("checked_in_at")
  inProgressAt          DateTime?         @map("in_progress_at")
  completionNotes       String?           @map("completion_notes")
  isWalkIn              Boolean           @default(false) @map("is_walk_in")
  recurringGroupId      String?           @map("recurring_group_id")
  recurringPattern      RecurringPattern? @map("recurring_pattern")
  rescheduleCount       Int               @default(0) @map("reschedule_count")
  suggestedRefundType   RefundType?       @map("suggested_refund_type")
  durationOptionId      String?           @map("duration_option_id")
  // SNAPSHOT — captured at creation, immutable. Used for invoicing and refunds.
  // Do NOT recalculate from current service prices — those may have changed.
  bookedPrice           Int?              @map("booked_price") // halalat
  bookedDuration        Int?              @map("booked_duration") // minutes

  patient             User?               @relation("PatientBookings", fields: [patientId], references: [id], onDelete: SetNull)
  branch              Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  practitioner        Practitioner        @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  service             Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  practitionerService PractitionerService @relation(fields: [practitionerServiceId], references: [id], onDelete: Restrict)
  rescheduledFrom     Booking?            @relation("RescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo       Booking?            @relation("RescheduleChain")
  payment             Payment?
  rating              Rating?
  problemReports      ProblemReport[]
  statusLogs          BookingStatusLog[]
  intakeResponses     IntakeResponse[]
  waitlistConversions WaitlistEntry[]     @relation("WaitlistBooking")

  @@index([practitionerId, date])
  @@index([practitionerId, status])
  @@index([patientId, status])
  @@index([status])
  @@index([status, date])
  @@index([branchId])
  @@index([branchId, date])
  @@index([branchId, status])
  @@index([practitionerServiceId])
  @@index([date])
  @@index([createdAt])
  @@index([recurringGroupId])
  @@map("bookings")
}

// MULTI-BRANCH DESIGN:
// branchId = null  → global default row (singleton, seeded at startup)
// branchId = <id>  → branch-specific override row (one per branch)
// Resolution: BookingSettingsService.getForBranch(branchId) returns branch row ?? global row.
// Two partial unique indexes in migration 20260326050000 enforce singleton-per-scope at DB level.
model BookingSettings {
  id       String  @id @default(uuid())
  // null = global default. Non-null = branch override.
  branchId String? @map("branch_id")

  // Payment timeout
  paymentTimeoutMinutes Int @default(60) @map("payment_timeout_minutes")

  // Cancellation policy
  freeCancelBeforeHours   Int        @default(24) @map("free_cancel_before_hours")
  freeCancelRefundType    RefundType @default(full) @map("free_cancel_refund_type")
  lateCancelRefundType    RefundType @default(none) @map("late_cancel_refund_type")
  lateCancelRefundPercent Int        @default(0) @map("late_cancel_refund_percent")
  adminCanDirectCancel    Boolean    @default(true) @map("admin_can_direct_cancel")
  patientCanCancelPending Boolean    @default(true) @map("patient_can_cancel_pending")

  // Rescheduling policy
  patientCanReschedule     Boolean @default(true) @map("patient_can_reschedule")
  rescheduleBeforeHours    Int     @default(12) @map("reschedule_before_hours")
  maxReschedulesPerBooking Int     @default(2) @map("max_reschedules_per_booking")

  // Walk-in
  allowWalkIn           Boolean @default(true) @map("allow_walk_in")
  walkInPaymentRequired Boolean @default(false) @map("walk_in_payment_required")

  // Recurring
  allowRecurring           Boolean            @default(false) @map("allow_recurring")
  maxRecurrences           Int                @default(12) @map("max_recurrences")
  allowedRecurringPatterns RecurringPattern[] @default([weekly, biweekly]) @map("allowed_recurring_patterns")

  // Waitlist
  waitlistEnabled    Boolean @default(false) @map("waitlist_enabled")
  waitlistMaxPerSlot Int     @default(5) @map("waitlist_max_per_slot")
  waitlistAutoNotify Boolean @default(true) @map("waitlist_auto_notify")

  // Buffer between appointments
  bufferMinutes Int @default(0) @map("buffer_minutes")

  // Auto-complete / no-show
  autoCompleteAfterHours Int          @default(2) @map("auto_complete_after_hours")
  autoNoShowAfterMinutes Int          @default(30) @map("auto_no_show_after_minutes")
  noShowPolicy           NoShowPolicy @default(keep_full) @map("no_show_policy")
  noShowRefundPercent    Int          @default(0) @map("no_show_refund_percent")

  // Cancellation review
  cancellationReviewTimeoutHours Int    @default(48) @map("cancellation_review_timeout_hours")
  cancellationPolicyEn           String @default("") @map("cancellation_policy_en")
  cancellationPolicyAr           String @default("") @map("cancellation_policy_ar")

  // Reminders
  reminder24hEnabled  Boolean @default(true) @map("reminder_24h_enabled")
  reminder1hEnabled   Boolean @default(true) @map("reminder_1h_enabled")
  reminderInteractive Boolean @default(false) @map("reminder_interactive")

  // Suggestions
  suggestAlternativesOnConflict Boolean @default(true) @map("suggest_alternatives_on_conflict")
  suggestAlternativesCount      Int     @default(3) @map("suggest_alternatives_count")

  // Lead time & admin
  minBookingLeadMinutes    Int     @default(0) @map("min_booking_lead_minutes")
  adminCanBookOutsideHours Boolean @default(false) @map("admin_can_book_outside_hours")
  maxAdvanceBookingDays    Int     @default(60) @map("max_advance_booking_days")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("booking_settings")
}

model WaitlistEntry {
  id              String         @id @default(uuid())
  patientId       String         @map("patient_id")
  practitionerId  String         @map("practitioner_id")
  serviceId       String?        @map("service_id")
  preferredDate   DateTime?      @map("preferred_date")
  preferredTime   PreferredTime? @map("preferred_time")
  status          WaitlistStatus @default(waiting)
  notifiedAt      DateTime?      @map("notified_at")
  bookedBookingId String?        @map("booked_booking_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  patient       User         @relation("WaitlistPatient", fields: [patientId], references: [id], onDelete: Cascade)
  practitioner  Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  service       Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  bookedBooking Booking?     @relation("WaitlistBooking", fields: [bookedBookingId], references: [id], onDelete: SetNull)

  @@index([practitionerId, status])
  @@index([patientId])
  @@map("waitlist_entries")
}

// DOMAIN NOTE: FavoritePractitioner logically belongs to the Patient/Clinic domain,
// but lives here alongside booking-related patient relations for cohesion.
// Future extraction: move to clinic.prisma if a dedicated Patient module is created.
model FavoritePractitioner {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  practitionerId String   @map("practitioner_id")
  createdAt      DateTime @default(now()) @map("created_at")

  patient      User         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@unique([patientId, practitionerId])
  @@map("favorite_practitioners")
}

// Audit trail for every status transition.
// Complements the snapshot timestamps on Booking (confirmedAt, completedAt, etc.)
// which exist for fast single-row reads without joining this table.
// changedBy: user UUID or 'system' for automated transitions (expiry, no-show tasks).
model BookingStatusLog {
  id         String   @id @default(uuid())
  bookingId  String   @map("booking_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by") // user_id or 'system'
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_logs")
}

// DOMAIN NOTE: IntakeForm straddles two domains:
//   - Definition (scope/fields) belongs to Services/Clinic domain
//   - Responses (answers per booking) belong to Bookings domain
// Kept here because IntakeResponse.bookingId anchors it to this domain.
// The service/practitioner/branch FK on IntakeForm is acceptable cross-domain reference.
model IntakeForm {
  id               String    @id @default(uuid())
  nameAr           String    @map("name_ar")
  nameEn           String    @map("name_en")
  type             FormType  @map("type")
  scope            FormScope @map("scope")
  serviceId        String?   @map("service_id")
  practitionerId   String?   @map("practitioner_id")
  branchId         String?   @map("branch_id")
  isActive         Boolean   @default(true) @map("is_active")
  submissionsCount Int       @default(0) @map("submissions_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  service      Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  practitioner Practitioner?    @relation(fields: [practitionerId], references: [id], onDelete: SetNull)
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  fields       IntakeField[]
  responses    IntakeResponse[]

  @@index([scope])
  @@index([serviceId])
  @@index([practitionerId])
  @@index([branchId])
  @@map("intake_forms")
}

model IntakeField {
  id         String  @id @default(uuid())
  formId     String  @map("form_id")
  labelAr    String  @map("label_ar")
  labelEn    String  @map("label_en")
  fieldType  String  @map("field_type")
  options    Json?
  condition  Json?
  isRequired Boolean @default(false) @map("is_required")
  sortOrder  Int     @default(0) @map("sort_order")

  form IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("intake_fields")
}

model IntakeResponse {
  id        String   @id @default(uuid())
  formId    String   @map("form_id")
  bookingId String   @map("booking_id")
  patientId String   @map("patient_id")
  answers   Json
  createdAt DateTime @default(now()) @map("created_at")

  form    IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  booking Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([bookingId])
  @@map("intake_responses")
}
