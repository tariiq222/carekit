// ──────────────────────────────────────────────
// Clinic — Practitioners & Schedule
// ──────────────────────────────────────────────

model Specialty {
  id            String   @id @default(uuid())
  nameEn        String   @unique @map("name_en")
  nameAr        String   @map("name_ar")
  descriptionEn String?  @map("description_en")
  descriptionAr String?  @map("description_ar")
  iconUrl       String?  @map("icon_url")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  practitioners Practitioner[]

  @@index([isActive, sortOrder])
  @@map("specialties")
}

model Practitioner {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  title               String?   @map("title")
  nameAr              String?   @map("name_ar")
  specialtyId         String?   @map("specialty_id")
  specialty           String    @default("") @map("specialty")
  specialtyAr         String    @default("") @map("specialty_ar")
  bio                 String?
  bioAr               String?   @map("bio_ar")
  experience          Int       @default(0)
  education           String?
  educationAr         String?   @map("education_ar")
  // INTENTIONAL DENORMALIZATION: cached aggregates — updated by application on every Rating CRUD
  // Avoids COUNT/AVG on ratings table per request. Must stay in sync via service layer.
  // Source of truth: ratings table. These are read-optimized projections only.
  rating              Float     @default(0)
  reviewCount         Int       @default(0) @map("review_count")
  isActive            Boolean   @default(true) @map("is_active")
  isAcceptingBookings Boolean   @default(true) @map("is_accepting_bookings")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialtyRel         Specialty?                 @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  availabilities       PractitionerAvailability[]
  vacations            PractitionerVacation[]
  breaks               PractitionerBreak[]
  bookings             Booking[]
  ratings              Rating[]
  practitionerServices PractitionerService[]
  waitlistEntries      WaitlistEntry[]
  favoritedBy          FavoritePractitioner[]
  branches             PractitionerBranch[]
  intakeForms          IntakeForm[]
  groupSessions        GroupSession[]
  courses              Course[]

  @@index([isActive, deletedAt])
  @@map("practitioners")
}

model PractitionerAvailability {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  dayOfWeek      Int      @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime      String   @map("start_time") // "HH:mm"
  endTime        String   @map("end_time") // "HH:mm"
  isActive       Boolean  @default(true) @map("is_active")
  // Multi-branch: null = available at all branches (default, backward-compatible).
  // Non-null = availability scoped to this branch only.
  branchId       String?  @map("branch_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([practitionerId, dayOfWeek, isActive, branchId])
  @@map("practitioner_availabilities")
}

model PractitionerVacation {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId])
  @@index([startDate, endDate])
  @@map("practitioner_vacations")
}

model PractitionerBreak {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  dayOfWeek      Int      @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime      String   @map("start_time") // "HH:mm"
  endTime        String   @map("end_time") // "HH:mm"
  createdAt      DateTime @default(now()) @map("created_at")

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, dayOfWeek])
  @@map("practitioner_breaks")
}

model ClinicWorkingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  branchId  String?  @map("branch_id")

  @@unique([dayOfWeek, branchId], name: "clinic_working_hours_day_branch_idx")
  @@index([branchId], name: "clinic_working_hours_branch_id_idx")
  @@map("clinic_working_hours")
}

model ClinicHoliday {
  id          String   @id @default(uuid())
  date        DateTime
  nameAr      String   @map("name_ar")
  nameEn      String   @map("name_en")
  isRecurring Boolean  @default(false) @map("is_recurring")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@map("clinic_holidays")
}

model Branch {
  id        String    @id @default(uuid())
  nameAr    String    @map("name_ar")
  nameEn    String    @map("name_en")
  address   String?
  phone     String?
  email     String?
  isMain    Boolean   @default(false) @map("is_main")
  isActive  Boolean   @default(true) @map("is_active")
  timezone  String    @default("Asia/Riyadh")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  practitioners              PractitionerBranch[]
  intakeForms                IntakeForm[]
  practitionerAvailabilities PractitionerAvailability[]
  bookingSettings            BookingSettings[]
  bookings                   Booking[]
  services                   ServiceBranch[]

  @@map("branches")
}

model PractitionerBranch {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  branchId       String   @map("branch_id")
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([practitionerId, branchId])
  @@index([branchId])
  @@map("practitioner_branches")
}
