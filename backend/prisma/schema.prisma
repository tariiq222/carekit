// CareKit — Prisma Schema (ERD)
// Single source of truth for database structure
// Changes require Schema Change Protocol approval from maestro

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum BookingType {
  clinic_visit
  phone_consultation
  video_consultation
  walk_in

  @@map("booking_type")
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  in_progress
  completed
  cancelled
  pending_cancellation
  no_show
  expired

  @@map("booking_status")
}

enum PaymentMethod {
  moyasar
  bank_transfer

  @@map("payment_method")
}

enum PaymentStatus {
  pending
  awaiting
  paid
  refunded
  failed
  rejected // Bank transfer receipt rejected by admin — audit trail preserved

  @@map("payment_status")
}

enum TransferVerificationStatus {
  pending
  matched
  amount_differs
  suspicious
  old_date
  unreadable
  approved
  rejected

  @@map("transfer_verification_status")
}

enum NotificationType {
  booking_confirmed
  booking_completed
  booking_cancelled
  booking_rescheduled
  booking_expired
  booking_no_show
  booking_reminder
  booking_reminder_urgent
  booking_cancellation_rejected
  cancellation_rejected
  cancellation_requested
  no_show_review
  patient_arrived
  receipt_rejected
  reminder
  payment_received
  new_rating
  problem_report
  waitlist_slot_available
  system_alert

  @@map("notification_type")
}

enum WaitlistStatus {
  waiting
  notified
  booked
  expired
  cancelled

  @@map("waitlist_status")
}

enum ProblemReportType {
  wait_time
  staff_behavior
  cleanliness
  billing
  no_call
  late
  technical
  other

  @@map("problem_report_type")
}

enum ProblemReportStatus {
  open
  in_review
  resolved
  dismissed

  @@map("problem_report_status")
}

enum ChatRole {
  user
  assistant
  system
  staff

  @@map("chat_role")
}

enum HandoffType {
  live_chat
  contact_number

  @@map("handoff_type")
}

enum ConfigValueType {
  string
  json
  file

  @@map("config_value_type")
}

enum UserGender {
  male
  female

  @@map("user_gender")
}

enum ZatcaStatus {
  not_applicable
  pending
  reported
  failed

  @@map("zatca_status")
}

enum OtpType {
  login
  reset_password
  verify_email

  @@map("otp_type")
}

enum KbFileStatus {
  pending
  processing
  completed
  failed

  @@map("kb_file_status")
}

enum DevicePlatform {
  ios
  android

  @@map("device_platform")
}

enum RecurringPattern {
  daily
  every_2_days
  every_3_days
  weekly
  biweekly
  monthly

  @@map("recurring_pattern")
}

enum SessionLanguage {
  ar
  en

  @@map("session_language")
}

enum AccountType {
  FULL
  WALK_IN

  @@map("account_type")
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN

  @@map("blood_type")
}

// ──────────────────────────────────────────────
// Auth & Users
// ──────────────────────────────────────────────

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String?     @map("password_hash")
  firstName     String      @map("first_name")
  middleName    String?     @map("middle_name")
  lastName      String      @map("last_name")
  phone         String?     @unique
  gender        UserGender?
  avatarUrl     String?     @map("avatar_url")
  accountType   AccountType @default(FULL) @map("account_type")
  claimedAt     DateTime?   @map("claimed_at")
  isActive      Boolean     @default(true) @map("is_active")
  emailVerified Boolean     @default(false) @map("email_verified")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  // Relations
  otpCodes              OtpCode[]
  refreshTokens         RefreshToken[]
  userRoles             UserRole[]
  practitioner          Practitioner?
  bookingsAsPatient     Booking[]              @relation("PatientBookings")
  ratingsAsPatient      Rating[]               @relation("PatientRatings")
  problemReports        ProblemReport[]        @relation("PatientProblemReports")
  resolvedReports       ProblemReport[]        @relation("ResolvedByUser")
  reviewedReceipts      BankTransferReceipt[]  @relation("ReviewedByUser")
  chatSessions          ChatSession[]
  notifications         Notification[]
  fcmTokens             FcmToken[]
  activityLogs          ActivityLog[]
  kbFiles               KnowledgeBaseFile[]
  waitlistEntries       WaitlistEntry[]        @relation("WaitlistPatient")
  favoritePractitioners FavoritePractitioner[]
  patientProfile        PatientProfile?

  @@map("users")
}

model PatientProfile {
  id                   String     @id @default(uuid())
  userId               String     @unique @map("user_id")
  // Identity
  nationalId           String?    @map("national_id")
  nationality          String?
  dateOfBirth          DateTime?  @map("date_of_birth")
  // Emergency contact
  emergencyName        String?    @map("emergency_name")
  emergencyPhone       String?    @map("emergency_phone")
  // Medical basics
  bloodType            BloodType?  @map("blood_type")
  allergies            String?     // نص حر — أدوية وأغذية
  chronicConditions    String?     @map("chronic_conditions")

  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model OtpCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  code      String
  type      OtpType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // H9: Composite index for atomic OTP verification (userId + type + usedAt)
  @@index([userId, type, usedAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // For scheduled cleanup of expired tokens
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────
// RBAC
// ──────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id            String   @id @default(uuid())
  module        String
  action        String
  description   String?
  descriptionAr String?  @map("description_ar")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ──────────────────────────────────────────────
// Clinic
// ──────────────────────────────────────────────

model Practitioner {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  specialty   String    @default("") @map("specialty")
  specialtyAr String    @default("") @map("specialty_ar")
  bio         String?
  bioAr       String?   @map("bio_ar")
  experience  Int       @default(0)
  education   String?
  educationAr String?   @map("education_ar")
  priceClinic Int       @default(0) @map("price_clinic") // halalat
  pricePhone  Int       @default(0) @map("price_phone") // halalat
  priceVideo  Int       @default(0) @map("price_video") // halalat
  rating      Float     @default(0)
  reviewCount Int       @default(0) @map("review_count")
  isActive             Boolean   @default(true) @map("is_active")
  isAcceptingBookings  Boolean   @default(true) @map("is_accepting_bookings")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  // Relations
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities       PractitionerAvailability[]
  vacations            PractitionerVacation[]
  breaks               PractitionerBreak[]
  bookings             Booking[]
  ratings              Rating[]
  practitionerServices PractitionerService[]
  waitlistEntries      WaitlistEntry[]
  favoritedBy          FavoritePractitioner[]
  branches             PractitionerBranch[]

  @@index([isActive, deletedAt])
  @@map("practitioners")
}

model PractitionerAvailability {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  dayOfWeek      Int      @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime      String   @map("start_time") // "HH:mm"
  endTime        String   @map("end_time") // "HH:mm"
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  // H10: Add isActive to composite index to avoid filtering in-memory after index lookup
  @@index([practitionerId, dayOfWeek, isActive])
  @@map("practitioner_availabilities")
}

model PractitionerVacation {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId])
  @@map("practitioner_vacations")
}

model PractitionerBreak {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  dayOfWeek      Int      @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime      String   @map("start_time") // "HH:mm"
  endTime        String   @map("end_time") // "HH:mm"
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, dayOfWeek])
  @@map("practitioner_breaks")
}

model PractitionerService {
  id             String        @id @default(uuid())
  practitionerId String        @map("practitioner_id")
  serviceId      String        @map("service_id")
  priceClinic    Int?          @map("price_clinic") // halalat — null = use fallback
  pricePhone     Int?          @map("price_phone") // halalat — null = use fallback
  priceVideo     Int?          @map("price_video") // halalat — null = use fallback
  customDuration Int?          @map("custom_duration") // minutes — overrides service.duration
  bufferMinutes  Int           @default(0) @map("buffer_minutes") // buffer applied before and after appointment
  availableTypes BookingType[] @map("available_types") // supported booking types
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  practitioner Practitioner              @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  service      Service                   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  serviceTypes PractitionerServiceType[]

  @@unique([practitionerId, serviceId])
  @@index([serviceId])
  @@map("practitioner_services")
}

// ──────────────────────────────────────────────
// Services
// ──────────────────────────────────────────────

model ServiceCategory {
  id        String   @id @default(uuid())
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  services Service[]

  @@map("service_categories")
}

model Service {
  id                    String  @id @default(uuid())
  nameAr                String  @map("name_ar")
  nameEn                String  @map("name_en")
  descriptionAr         String? @map("description_ar")
  descriptionEn         String? @map("description_en")
  categoryId            String  @map("category_id")
  price                 Int     @default(0) // halalat
  duration              Int     @default(30) // minutes
  isActive              Boolean @default(true) @map("is_active")
  isHidden              Boolean @default(false) @map("is_hidden")
  hidePriceOnBooking    Boolean @default(false) @map("hide_price_on_booking")
  hideDurationOnBooking Boolean @default(false) @map("hide_duration_on_booking")
  calendarColor         String? @map("calendar_color")

  // Booking settings per service
  bufferMinutes       Int     @default(0) @map("buffer_minutes") // override global setting; 0 = use global
  depositEnabled      Boolean @default(false) @map("deposit_enabled")
  depositPercent      Int     @default(100) @map("deposit_percent")
  allowRecurring              Boolean            @default(true) @map("allow_recurring")
  allowedRecurringPatterns    RecurringPattern[] @default([]) @map("allowed_recurring_patterns")
  maxRecurrences              Int                @default(12) @map("max_recurrences")
  maxParticipants             Int                @default(1) @map("max_participants")
  minLeadMinutes      Int?    @map("min_lead_minutes")
  maxAdvanceDays      Int?    @map("max_advance_days")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  category             ServiceCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bookings             Booking[]
  practitionerServices PractitionerService[]
  waitlistEntries      WaitlistEntry[]
  durationOptions      ServiceDurationOption[]
  intakeForms          IntakeForm[]
  bookingTypes         ServiceBookingType[]

  @@index([categoryId])
  @@map("services")
}

// ──────────────────────────────────────────────
// Service Duration Options
// ──────────────────────────────────────────────

model ServiceDurationOption {
  id                   String  @id @default(uuid())
  serviceId            String  @map("service_id")
  serviceBookingTypeId String? @map("service_booking_type_id")
  label                String
  labelAr              String? @map("label_ar")
  durationMinutes      Int     @map("duration_minutes")
  price                Int // halalat
  isDefault            Boolean @default(false) @map("is_default")
  sortOrder            Int     @default(0) @map("sort_order")

  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceBookingType ServiceBookingType? @relation(fields: [serviceBookingTypeId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([serviceBookingTypeId])
  @@map("service_duration_options")
}

// ──────────────────────────────────────────────
// Service Booking Types (per-type pricing)
// ──────────────────────────────────────────────

model ServiceBookingType {
  id          String      @id @default(uuid())
  serviceId   String      @map("service_id")
  bookingType BookingType @map("booking_type")
  price       Int // halalat
  duration    Int // minutes
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  service         Service                 @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  durationOptions ServiceDurationOption[]

  @@unique([serviceId, bookingType])
  @@index([serviceId])
  @@map("service_booking_types")
}

// ──────────────────────────────────────────────
// Practitioner Service Types (per-type overrides)
// ──────────────────────────────────────────────

model PractitionerServiceType {
  id                    String      @id @default(uuid())
  practitionerServiceId String      @map("practitioner_service_id")
  bookingType           BookingType @map("booking_type")
  price                 Int? // null = use ServiceBookingType.price
  duration              Int? // null = use ServiceBookingType.duration
  useCustomOptions      Boolean     @default(false) @map("use_custom_options")
  isActive              Boolean     @default(true) @map("is_active")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  practitionerService PractitionerService          @relation(fields: [practitionerServiceId], references: [id], onDelete: Cascade)
  durationOptions     PractitionerDurationOption[]

  @@unique([practitionerServiceId, bookingType])
  @@index([practitionerServiceId])
  @@map("practitioner_service_types")
}

// ──────────────────────────────────────────────
// Practitioner Duration Options
// ──────────────────────────────────────────────

model PractitionerDurationOption {
  id                        String  @id @default(uuid())
  practitionerServiceTypeId String  @map("practitioner_service_type_id")
  label                     String
  labelAr                   String? @map("label_ar")
  durationMinutes           Int     @map("duration_minutes")
  price                     Int // halalat
  isDefault                 Boolean @default(false) @map("is_default")
  sortOrder                 Int     @default(0) @map("sort_order")

  practitionerServiceType PractitionerServiceType @relation(fields: [practitionerServiceTypeId], references: [id], onDelete: Cascade)

  @@index([practitionerServiceTypeId])
  @@map("practitioner_duration_options")
}

// ──────────────────────────────────────────────
// Intake Forms
// ──────────────────────────────────────────────

model IntakeForm {
  id         String   @id @default(uuid())
  serviceId  String   @map("service_id")
  titleAr    String   @map("title_ar")
  titleEn    String   @map("title_en")
  isRequired Boolean  @default(false) @map("is_required")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  fields    IntakeField[]
  responses IntakeResponse[]

  @@index([serviceId])
  @@map("intake_forms")
}

model IntakeField {
  id         String  @id @default(uuid())
  formId     String  @map("form_id")
  labelAr    String  @map("label_ar")
  labelEn    String  @map("label_en")
  fieldType  String  @map("field_type")
  options    Json?
  isRequired Boolean @default(false) @map("is_required")
  sortOrder  Int     @default(0) @map("sort_order")

  form IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("intake_fields")
}

model IntakeResponse {
  id        String   @id @default(uuid())
  formId    String   @map("form_id")
  bookingId String   @map("booking_id")
  patientId String   @map("patient_id")
  answers   Json
  createdAt DateTime @default(now()) @map("created_at")

  form IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([bookingId])
  @@map("intake_responses")
}

// ──────────────────────────────────────────────
// Bookings
// ──────────────────────────────────────────────

model Booking {
  id                    String        @id @default(uuid())
  patientId             String?       @map("patient_id") // nullable ONLY for onDelete:SetNull — always required at creation
  practitionerId        String        @map("practitioner_id")
  serviceId             String        @map("service_id")
  practitionerServiceId String        @map("practitioner_service_id")
  type                  BookingType
  date                  DateTime
  startTime             String        @map("start_time") // "HH:mm"
  endTime               String        @map("end_time") // "HH:mm"
  status                BookingStatus @default(pending)
  notes                 String?
  zoomMeetingId         String?       @map("zoom_meeting_id")
  zoomJoinUrl           String?       @map("zoom_join_url")
  zoomHostUrl           String?       @map("zoom_host_url")
  cancellationReason    String?       @map("cancellation_reason")
  adminNotes            String?       @map("admin_notes")
  cancelledAt           DateTime?     @map("cancelled_at")
  confirmedAt           DateTime?     @map("confirmed_at")
  rescheduledFromId     String?       @unique @map("rescheduled_from_id")
  completedAt           DateTime?     @map("completed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  // New fields — booking overhaul
  cancelledBy         String?   @map("cancelled_by") // patient | practitioner | admin | system
  noShowAt            DateTime? @map("no_show_at")
  checkedInAt         DateTime? @map("checked_in_at")
  inProgressAt        DateTime? @map("in_progress_at")
  completionNotes     String?   @map("completion_notes")
  isWalkIn            Boolean   @default(false) @map("is_walk_in")
  recurringGroupId    String?           @map("recurring_group_id")
  recurringPattern    RecurringPattern? @map("recurring_pattern")
  rescheduleCount     Int       @default(0) @map("reschedule_count")
  suggestedRefundType String?   @map("suggested_refund_type")

  // Price/duration snapshot at booking time
  durationOptionId String? @map("duration_option_id")
  bookedPrice      Int?    @map("booked_price") // halalat
  bookedDuration   Int?    @map("booked_duration") // minutes

  // Relations
  patient             User?               @relation("PatientBookings", fields: [patientId], references: [id], onDelete: SetNull)
  practitioner        Practitioner        @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  service             Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  practitionerService PractitionerService @relation(fields: [practitionerServiceId], references: [id], onDelete: Restrict)
  rescheduledFrom     Booking?            @relation("RescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo       Booking?            @relation("RescheduleChain")
  payment             Payment?
  rating              Rating?
  problemReports      ProblemReport[]
  statusLogs          BookingStatusLog[]

  @@index([practitionerId, date])
  @@index([patientId, status])
  @@index([status])
  @@index([practitionerServiceId])
  @@index([date])
  @@index([recurringGroupId])
  @@map("bookings")
}

// ──────────────────────────────────────────────
// Booking Settings (admin-configurable per clinic)
// ──────────────────────────────────────────────

model BookingSettings {
  id String @id @default(uuid())

  // Payment timeout
  paymentTimeoutMinutes Int @default(60) @map("payment_timeout_minutes")

  // Cancellation policy
  freeCancelBeforeHours   Int     @default(24) @map("free_cancel_before_hours")
  freeCancelRefundType    String  @default("full") @map("free_cancel_refund_type")
  lateCancelRefundType    String  @default("none") @map("late_cancel_refund_type")
  lateCancelRefundPercent Int     @default(0) @map("late_cancel_refund_percent")
  adminCanDirectCancel    Boolean @default(true) @map("admin_can_direct_cancel")
  patientCanCancelPending Boolean @default(true) @map("patient_can_cancel_pending")

  // Rescheduling policy
  patientCanReschedule     Boolean @default(true) @map("patient_can_reschedule")
  rescheduleBeforeHours    Int     @default(12) @map("reschedule_before_hours")
  maxReschedulesPerBooking Int     @default(2) @map("max_reschedules_per_booking")

  // Walk-in
  allowWalkIn           Boolean @default(true) @map("allow_walk_in")
  walkInPaymentRequired Boolean @default(false) @map("walk_in_payment_required")

  // Recurring
  allowRecurring           Boolean            @default(false) @map("allow_recurring")
  maxRecurrences           Int                @default(12) @map("max_recurrences")
  allowedRecurringPatterns RecurringPattern[] @default([weekly, biweekly]) @map("allowed_recurring_patterns")

  // Waitlist
  waitlistEnabled    Boolean @default(false) @map("waitlist_enabled")
  waitlistMaxPerSlot Int     @default(5) @map("waitlist_max_per_slot")
  waitlistAutoNotify Boolean @default(true) @map("waitlist_auto_notify")

  // Buffer between appointments
  bufferMinutes Int @default(0) @map("buffer_minutes")

  // Auto-complete / no-show
  autoCompleteAfterHours Int    @default(2) @map("auto_complete_after_hours")
  autoNoShowAfterMinutes Int    @default(30) @map("auto_no_show_after_minutes")
  noShowPolicy           String @default("keep_full") @map("no_show_policy") // keep_full | partial_refund | admin_decides
  noShowRefundPercent    Int    @default(0) @map("no_show_refund_percent") // used when noShowPolicy = partial_refund

  // Cancellation review timeout
  cancellationReviewTimeoutHours Int @default(48) @map("cancellation_review_timeout_hours")

  // Cancellation policy text (displayed to patients)
  cancellationPolicyEn String @default("") @map("cancellation_policy_en")
  cancellationPolicyAr String @default("") @map("cancellation_policy_ar")

  // Reminders
  reminder24hEnabled  Boolean @default(true) @map("reminder_24h_enabled")
  reminder1hEnabled   Boolean @default(true) @map("reminder_1h_enabled")
  reminderInteractive Boolean @default(false) @map("reminder_interactive")

  // Suggestions
  suggestAlternativesOnConflict Boolean @default(true) @map("suggest_alternatives_on_conflict")
  suggestAlternativesCount      Int     @default(3) @map("suggest_alternatives_count")

  // Lead time
  minBookingLeadMinutes Int @default(0) @map("min_booking_lead_minutes")

  // Admin override
  adminCanBookOutsideHours Boolean @default(false) @map("admin_can_book_outside_hours")

  // Max advance booking window (days from today)
  maxAdvanceBookingDays Int @default(60) @map("max_advance_booking_days")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("booking_settings")
}

// ──────────────────────────────────────────────
// Waitlist
// ──────────────────────────────────────────────

model WaitlistEntry {
  id              String         @id @default(uuid())
  patientId       String         @map("patient_id")
  practitionerId  String         @map("practitioner_id")
  serviceId       String?        @map("service_id")
  preferredDate   DateTime?      @map("preferred_date")
  preferredTime   String?        @map("preferred_time") // "morning" | "afternoon" | "any"
  status          WaitlistStatus @default(waiting)
  notifiedAt      DateTime?      @map("notified_at")
  bookedBookingId String?        @map("booked_booking_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  patient      User         @relation("WaitlistPatient", fields: [patientId], references: [id], onDelete: Cascade)
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([practitionerId, status])
  @@index([patientId])
  @@map("waitlist_entries")
}

// ──────────────────────────────────────────────
// Favorite Practitioners
// ──────────────────────────────────────────────

model FavoritePractitioner {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  practitionerId String   @map("practitioner_id")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  patient      User         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@unique([patientId, practitionerId])
  @@map("favorite_practitioners")
}

// ──────────────────────────────────────────────
// Payments
// ──────────────────────────────────────────────

model Payment {
  id               String        @id @default(uuid())
  bookingId        String        @unique @map("booking_id")
  amount           Int // halalat
  vatAmount        Int           @default(0) @map("vat_amount") // halalat
  totalAmount      Int           @default(0) @map("total_amount") // halalat
  refundAmount     Int?          @map("refund_amount") // halalat — null = no refund, totalAmount = full refund
  method           PaymentMethod
  status           PaymentStatus @default(pending)
  moyasarPaymentId String?       @unique @map("moyasar_payment_id")
  transactionRef   String?       @map("transaction_ref")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  // Relations
  booking Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  receipt BankTransferReceipt?
  invoice Invoice?

  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model BankTransferReceipt {
  id                   String                     @id @default(uuid())
  paymentId            String                     @unique @map("payment_id")
  receiptUrl           String                     @map("receipt_url")
  aiVerificationStatus TransferVerificationStatus @default(pending) @map("ai_verification_status")
  aiConfidence         Float?                     @map("ai_confidence")
  aiNotes              String?                    @map("ai_notes")
  extractedAmount      Int?                       @map("extracted_amount") // halalat
  extractedDate        DateTime?                  @map("extracted_date")
  reviewedById         String?                    @map("reviewed_by_id")
  reviewedAt           DateTime?                  @map("reviewed_at")
  adminNotes           String?                    @map("admin_notes")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  deletedAt            DateTime?                  @map("deleted_at")

  // Relations
  payment    Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("ReviewedByUser", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("bank_transfer_receipts")
}

model Invoice {
  id            String      @id @default(uuid())
  paymentId     String      @unique @map("payment_id")
  invoiceNumber String      @unique @map("invoice_number")
  pdfUrl        String?     @map("pdf_url")
  sentAt        DateTime?   @map("sent_at")
  vatAmount     Int         @default(0) @map("vat_amount")
  vatRate       Int         @default(0) @map("vat_rate")
  invoiceHash   String?     @map("invoice_hash")
  previousHash  String?     @map("previous_hash")
  qrCodeData    String?     @map("qr_code_data")
  zatcaStatus   ZatcaStatus @default(not_applicable) @map("zatca_status")
  zatcaResponse Json?       @map("zatca_response")
  xmlContent    String?     @map("xml_content")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model ProcessedWebhook {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_webhooks")
}

// ──────────────────────────────────────────────
// Ratings
// ──────────────────────────────────────────────

model Rating {
  id             String    @id @default(uuid())
  bookingId      String    @unique @map("booking_id")
  patientId      String?   @map("patient_id")
  practitionerId String    @map("practitioner_id")
  stars          Int // 1-5
  comment        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient      User?        @relation("PatientRatings", fields: [patientId], references: [id], onDelete: SetNull)
  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId])
  @@map("ratings")
}

model ProblemReport {
  id           String              @id @default(uuid())
  bookingId    String              @map("booking_id")
  patientId    String?             @map("patient_id")
  type         ProblemReportType
  description  String
  status       ProblemReportStatus @default(open)
  adminNotes   String?             @map("admin_notes")
  resolvedById String?             @map("resolved_by_id")
  resolvedAt   DateTime?           @map("resolved_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  // Relations
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient    User?   @relation("PatientProblemReports", fields: [patientId], references: [id], onDelete: SetNull)
  resolvedBy User?   @relation("ResolvedByUser", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([patientId])
  @@index([status])
  @@map("problem_reports")
}

// ──────────────────────────────────────────────
// Chatbot
// ──────────────────────────────────────────────

model ChatSession {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  startedAt   DateTime         @default(now()) @map("started_at")
  endedAt     DateTime?        @map("ended_at")
  handedOff   Boolean          @default(false) @map("handed_off")
  handoffType HandoffType?     @map("handoff_type")
  language    SessionLanguage? // detected from first message
  metadata    Json? // bot version, model used, etc.
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  role         ChatRole
  content      String
  functionCall Json?    @map("function_call")
  intent       String? // book | modify | cancel | query | handoff | greeting
  toolName     String?  @map("tool_name")
  tokenCount   Int?     @map("token_count")
  staffId      String?  @map("staff_id") // staff user who sent this message (role=staff only)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model KnowledgeBase {
  id         String                       @id @default(uuid())
  title      String
  content    String
  embedding  Unsupported("vector(1536)")?
  category   String?
  source     String? // manual | auto_sync | file_upload
  fileId     String?                      @map("file_id")
  chunkIndex Int?                         @map("chunk_index")
  isActive   Boolean                      @default(true) @map("is_active")
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")

  @@index([source])
  @@index([fileId])
  @@map("knowledge_base")
}

// ──────────────────────────────────────────────
// Chatbot Configuration (White Label)
// ──────────────────────────────────────────────

model ChatbotConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  category  String // personality | rules | handoff | quick_replies | sync | ai_model
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("chatbot_config")
}

model KnowledgeBaseFile {
  id          String       @id @default(uuid())
  fileName    String       @map("file_name")
  fileUrl     String       @map("file_url")
  fileType    String       @map("file_type") // pdf | docx | txt
  fileSize    Int          @map("file_size") // bytes
  chunksCount Int          @default(0) @map("chunks_count")
  status      KbFileStatus @default(pending)
  error       String?
  uploadedBy  String       @map("uploaded_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [uploadedBy], references: [id])

  @@map("knowledge_base_files")
}

// ──────────────────────────────────────────────
// White Label
// ──────────────────────────────────────────────

model WhiteLabelConfig {
  id          String          @id @default(uuid())
  key         String          @unique
  value       String
  type        ConfigValueType @default(string)
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("white_label_config")
}

// ──────────────────────────────────────────────
// Booking Status Audit
// ──────────────────────────────────────────────

model BookingStatusLog {
  id         String   @id @default(uuid())
  bookingId  String   @map("booking_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by") // user_id or 'system'
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_logs")
}

// ──────────────────────────────────────────────
// Audit
// ──────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String // created | updated | deleted | login | logout | approved | rejected
  module      String // bookings | users | practitioners | payments | whitelabel | roles | ...
  resourceId  String?  @map("resource_id")
  description String?
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ──────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  titleAr   String           @map("title_ar")
  titleEn   String           @map("title_en")
  bodyAr    String           @map("body_ar")
  bodyEn    String           @map("body_en")
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  data      Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model FcmToken {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  token     String
  platform  DevicePlatform
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("fcm_tokens")
}

// ──────────────────────────────────────────────
// Clinic Configuration
// ──────────────────────────────────────────────

model ClinicWorkingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([dayOfWeek])
  @@map("clinic_working_hours")
}

model ClinicHoliday {
  id          String   @id @default(uuid())
  date        DateTime
  nameAr      String   @map("name_ar")
  nameEn      String   @map("name_en")
  isRecurring Boolean  @default(false) @map("is_recurring")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@map("clinic_holidays")
}

// ──────────────────────────────────────────────
// Coupons
// ──────────────────────────────────────────────

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  descriptionAr  String?   @map("description_ar")
  descriptionEn  String?   @map("description_en")
  discountType   String    @map("discount_type")
  discountValue  Int       @map("discount_value")
  minAmount      Int       @default(0) @map("min_amount")
  maxUses        Int?      @map("max_uses")
  usedCount      Int       @default(0) @map("used_count")
  maxUsesPerUser Int?      @map("max_uses_per_user")
  serviceIds     String[]  @map("service_ids")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  redemptions CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String   @map("coupon_id")
  userId    String   @map("user_id")
  bookingId String?  @map("booking_id")
  amount    Int
  createdAt DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

// ──────────────────────────────────────────────
// Branches
// ──────────────────────────────────────────────

model Branch {
  id        String    @id @default(uuid())
  nameAr    String    @map("name_ar")
  nameEn    String    @map("name_en")
  address   String?
  phone     String?
  email     String?
  isMain    Boolean   @default(false) @map("is_main")
  isActive  Boolean   @default(true) @map("is_active")
  timezone  String    @default("Asia/Riyadh")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  practitioners PractitionerBranch[]

  @@map("branches")
}

model PractitionerBranch {
  id             String   @id @default(uuid())
  practitionerId String   @map("practitioner_id")
  branchId       String   @map("branch_id")
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  practitioner Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([practitionerId, branchId])
  @@index([branchId])
  @@map("practitioner_branches")
}

// ──────────────────────────────────────────────
// Gift Cards
// ──────────────────────────────────────────────

model GiftCard {
  id            String    @id @default(uuid())
  code          String    @unique
  initialAmount Int       @map("initial_amount")
  balance       Int
  purchasedBy   String?   @map("purchased_by")
  redeemedBy    String?   @map("redeemed_by")
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  transactions GiftCardTransaction[]

  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String   @id @default(uuid())
  giftCardId String   @map("gift_card_id")
  amount     Int // positive = credit, negative = debit
  bookingId  String?  @map("booking_id")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@map("gift_card_transactions")
}


// ──────────────────────────────────────────────
// Email Templates
// ──────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(uuid())
  slug      String   @unique
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  subjectAr String   @map("subject_ar")
  subjectEn String   @map("subject_en")
  bodyAr    String   @map("body_ar") @db.Text
  bodyEn    String   @map("body_en") @db.Text
  variables Json     @default("[]")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}
