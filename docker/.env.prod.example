# Deqah Production Environment
# Copy to .env.prod and fill in all values
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Database ──
POSTGRES_USER=deqah
POSTGRES_PASSWORD=
POSTGRES_DB=deqah

# ── Redis ──
REDIS_PASSWORD=

# ── JWT (generate with: openssl rand -base64 64) ──
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Backend ──
BACKEND_PORT=3100
BACKEND_URL=https://api.yourclinic.com
ALLOWED_ORIGINS=https://dashboard.yourclinic.com

# ── AI (OpenRouter) ──
OPENROUTER_API_KEY=

# ── Storage (MinIO) ──
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=false

# ── Email ──
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourclinic.com

# ── Firebase (Push Notifications) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Zoom (Video Consultations) ──
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── SMS (optional) ──
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# ── Sentry error tracking ──
SENTRY_DSN=

# ── Prometheus metrics (required in production — app refuses to start without it) ──
# Generate with: openssl rand -hex 32
METRICS_TOKEN=

# ── Cookie domain ──
COOKIE_DOMAIN=.yourclinic.com

# ── Backup ──
BACKUP_RETENTION_DAYS=30
# Generate with: openssl rand -base64 48
# WARNING: Losing this key makes existing backups unrestorable. Store separately from backup files.
BACKUP_ENCRYPTION_KEY=
