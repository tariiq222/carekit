      "tasks": [
        { "id": "p12-t1", "title": "api/dashboard/ controllers", "detail": "One controller per BC: bookings, finance, people, clinic, comms, ops, platform, ai, media", "complexity": "MEDIUM", "status": "todo", "bc": "api" },
        { "id": "p12-t2", "title": "api/mobile/patient/ controllers", "detail": "bookings/, profile/, history/, payments/ — lightweight single-BC responses", "complexity": "MEDIUM", "status": "todo", "bc": "api" },
        { "id": "p12-t3", "title": "api/mobile/patient/portal/home", "detail": "BFF: aggregates bookings + invoices + messages + profile in 1 call", "complexity": "MEDIUM", "status": "todo", "bc": "api" },
        { "id": "p12-t4", "title": "api/mobile/patient/portal/upcoming + summary", "detail": "Lightweight composite endpoints per screen", "complexity": "MEDIUM", "status": "todo", "bc": "api" },
        { "id": "p12-t5", "title": "api/mobile/practitioner/ controllers", "detail": "schedule/, patients/, earnings/", "complexity": "MEDIUM", "status": "todo", "bc": "api" },
        { "id": "p12-t6", "title": "api/public/ controllers", "detail": "No-auth endpoints for landing page data", "complexity": "CRUD", "status": "todo", "bc": "api" }
