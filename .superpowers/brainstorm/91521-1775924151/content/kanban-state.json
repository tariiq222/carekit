    {
      "id": "p9",
      "title": "Comms BC",
      "titleAr": "التواصل والإشعارات",
      "description": "All outbound communication — event-driven, no direct calls from other BCs",
      "order": 9,
      "tasks": [
        { "id": "p9-t1", "title": "send-push + send-email + send-sms slices", "detail": "Core communication commands. Each wraps its infrastructure adapter", "complexity": "MEDIUM", "status": "todo", "bc": "comms" },
        { "id": "p9-t2", "title": "create-chat-message + list-conversations slices", "detail": "In-app messaging between patient and clinic", "complexity": "MEDIUM", "status": "todo", "bc": "comms" },
        { "id": "p9-t3", "title": "email-templates CRUD slices", "detail": "Editable templates with variable substitution", "complexity": "CRUD", "status": "todo", "bc": "comms" },
        { "id": "p9-t4", "title": "Comms event handlers", "detail": "on-booking-cancelled, on-reminder-due, on-payment-failed, on-patient-enrolled", "complexity": "MEDIUM", "status": "todo", "bc": "comms" }
      ]
    },
    {
      "id": "p10",
      "title": "Ops BC",
      "titleAr": "العمليات والتقارير",
      "description": "Cron jobs, activity log, reports, health check",
      "order": 10,
      "tasks": [
        { "id": "p10-t1", "title": "Cron task slices (5 jobs)", "detail": "booking-autocomplete, booking-expiry, booking-noshow, appointment-reminders, group-session-automation", "complexity": "MEDIUM", "status": "todo", "bc": "ops" },
        { "id": "p10-t2", "title": "log-activity slice", "detail": "Audit trail — logs all mutations from all BCs via event subscription", "complexity": "MEDIUM", "status": "todo", "bc": "ops" },
        { "id": "p10-t3", "title": "generate-report slice", "detail": "Revenue reports, activity reports, exports (PDF/Excel)", "complexity": "COMPLEX", "status": "todo", "bc": "ops" },
        { "id": "p10-t4", "title": "health-check slice", "detail": "Terminus health checks: DB, Redis, BullMQ, MinIO", "complexity": "CRUD", "status": "todo", "bc": "ops" }
      ]
    },
    {
      "id": "p11",
      "title": "AI BC",
      "titleAr": "الذكاء الاصطناعي",
      "description": "Chatbot, knowledge base, RAG pipeline — Enterprise tier only",
      "order": 11,
      "tasks": [
        { "id": "p11-t1", "title": "Knowledge base schema + embed-document slice", "detail": "pgvector storage, OpenAI embeddings, chunking strategy", "complexity": "COMPLEX", "status": "todo", "bc": "ai" },
        { "id": "p11-t2", "title": "semantic-search slice", "detail": "Vector similarity search with filters", "complexity": "COMPLEX", "status": "todo", "bc": "ai" },
        { "id": "p11-t3", "title": "chat-completion slice", "detail": "RAG pipeline: retrieve → augment → generate. Streaming response", "complexity": "COMPLEX", "status": "todo", "bc": "ai" },
        { "id": "p11-t4", "title": "manage-knowledge-base slice", "detail": "Add/remove/update documents in the knowledge base", "complexity": "MEDIUM", "status": "todo", "bc": "ai" }
      ]
