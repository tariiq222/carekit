{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth",
    "@openspoon/subtask2"
  ],
  "instructions": [
    "AGENTS.md",
    "opencode.md",
    ".opencode/agents/cto.md",
    ".opencode/agents/git-manager.md",
    ".opencode/agents/architect.md",
    ".opencode/agents/architect-opus.md",
    ".opencode/agents/executor.md",
    ".opencode/agents/test-engineer.md",
    ".opencode/agents/quick-reviewer.md",
    ".opencode/agents/deep-reviewer.md",
    ".opencode/agents/qa-validator.md",
    ".opencode/commands/نوقف.md",
    ".opencode/commands/نكمل.md"
  ],
  "agent": {
    "cto": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Master orchestrator — routes all tasks through the CareKit workflow. Start here.",
      "mode": "primary",
      "color": "#354FD8"
    },
    "git-manager": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Owns commit, PR, and changelog lifecycle. Classifies changes by system, writes accurate commit messages, manages GitHub PRs, and builds session logs.",
      "mode": "primary",
      "color": "#10b981"
    },
    "architect": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Analyzes tasks and produces implementation plans. Used by CTO only.",
      "mode": "subagent"
    },
    "architect-opus": {
      "model": "anthropic/claude-opus-4-6",
      "description": "High-complexity analysis only — escalation from architect. Used by CTO only.",
      "mode": "subagent"
    },
    "executor": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "description": "Implements approved plans with minimal scope. Used by CTO only.",
      "mode": "subagent"
    },
    "test-engineer": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "description": "Writes tests for every change. Used by CTO only.",
      "mode": "subagent"
    },
    "quick-reviewer": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "description": "Fast first-pass review — syntax, lint, TypeScript, obvious errors. Used by CTO only.",
      "mode": "subagent"
    },
    "deep-reviewer": {
      "model": "anthropic/claude-sonnet-4-6",
      "description": "Deep review — security, logic, plan adherence. Runs only when quick-reviewer flags issues. Used by CTO only.",
      "mode": "subagent"
    },
    "qa-validator": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "description": "Production risk simulation. Used by CTO only.",
      "mode": "subagent"
    }
  },
  "mcp": {
    "maestro": {
      "type": "local",
      "command": ["/bin/bash", "-c", "cd /Users/tariq/Documents/my_programs/maestro-mcp && ZAI_API_KEY=32167643b63240f88b09a03bd5f4f27a.96ub6isYe0PZYXnb npx tsx src/index.ts"],
      "enabled": true
    },

    "postgres": {
      "type": "local",
      "command": [
        "npx", "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://carekit:carekit_dev_password@localhost:5999/carekit_dev"
      ],
      "enabled": true
    },

    "redis": {
      "type": "local",
      "command": [
        "npx", "-y",
        "mcp-server-redis",
        "--url", "redis://localhost:5380"
      ],
      "enabled": true
    },

    "docker": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-docker"],
      "enabled": true
    },

    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },

    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
      "enabled": true
    },

    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },

    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },

    "filesystem": {
      "type": "local",
      "command": [
        "npx", "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/tariq/Documents/my_programs/CareKit"
      ],
      "enabled": true
    },

    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },

    "git": {
      "type": "local",
      "command": [
        "uvx", "mcp-server-git",
        "--repository", "/Users/tariq/Documents/my_programs/CareKit"
      ],
      "enabled": true
    },

    "prisma": {
      "type": "local",
      "command": [
        "/bin/bash", "-c",
        "cd /Users/tariq/Documents/my_programs/CareKit/backend && npx prisma mcp"
      ],
      "enabled": true
    },

    "sentry": {
      "type": "local",
      "command": ["npx", "-y", "@sentry/mcp-server"],
      "enabled": true,
      "environment": {
        "SENTRY_ACCESS_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_HOST": "https://sentry.io"
      }
    },

    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },

    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn-ui-mcp-server"],
      "enabled": true
    },

    "mobile": {
      "type": "local",
      "command": ["npx", "-y", "mobile-mcp"],
      "enabled": true
    },

    "ios-simulator": {
      "type": "local",
      "command": ["npx", "-y", "ios-simulator-mcp"],
      "enabled": true
    },

    "vibealive": {
      "type": "local",
      "command": [
        "npx", "-y", "vibealive",
        "--project", "/Users/tariq/Documents/my_programs/CareKit/dashboard"
      ],
      "enabled": true
    },

    "currents": {
      "type": "local",
      "command": ["npx", "-y", "@currents/mcp"],
      "enabled": false,
      "environment": {
        "CURRENTS_API_KEY": "$CURRENTS_API_KEY"
      }
    }
  }
}
