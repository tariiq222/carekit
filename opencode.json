{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth"
  ],
  "instructions": [
    "AGENTS.md"
  ],
  "mcp": {
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://carekit:carekit_dev_password@localhost:5999/carekit_dev"
      ],
      "enabled": true
    },
    "redis": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-redis",
        "--url",
        "redis://localhost:5380"
      ],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-docker"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    }
  }
}