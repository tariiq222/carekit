# Backend API base URL — must point to the NestJS backend in production
NEXT_PUBLIC_API_URL=http://localhost:5100/api/v1

# Dev-only: auto-fill login form credentials in development builds
# These are NEVER embedded in production builds (see next.config.mjs)
NEXT_PUBLIC_DEV_EMAIL=admin@deqah-test.com
NEXT_PUBLIC_DEV_PASSWORD=change-me

# hCaptcha Site Key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Moyasar browser-side publishable key. Never use a secret key in the dashboard.
NEXT_PUBLIC_MOYASAR_PLATFORM_PUBLISHABLE_KEY=pk_test_replace_me

# PostHog — analytics (client-side)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
