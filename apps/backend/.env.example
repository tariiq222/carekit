# CareKit Backend v2 environment
NODE_ENV=development
PORT=5100

# PostgreSQL — separate DB from v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carekit_v2?schema=public

# Redis (BullMQ + cache + token blacklist)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=carekit-v2
MINIO_USE_SSL=false

# JWT — dev placeholders (min 16 chars). Override for staging/prod.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# License Server (Platform BC)
LICENSE_SERVER_URL=
LICENSE_KEY=

# FCM (push notifications)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OpenAI (AI BC)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Moyasar (Finance BC)
MOYASAR_API_KEY=
MOYASAR_WEBHOOK_SECRET=
