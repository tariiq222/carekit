// Identity BC — auth, users, roles, permissions, OTP.

enum OtpChannel {
  EMAIL
  SMS
}

enum OtpPurpose {
  GUEST_BOOKING
  CLIENT_LOGIN
  CLIENT_PASSWORD_RESET
}

model OtpCode {
  id             String     @id @default(uuid())
  organizationId String?
  channel        OtpChannel
  identifier     String
  codeHash       String
  purpose        OtpPurpose
  expiresAt      DateTime
  consumedAt     DateTime?
  attempts       Int        @default(0)
  maxAttempts    Int        @default(5)
  lockedUntil    DateTime?
  createdAt      DateTime   @default(now())

  @@index([identifier, purpose])
  @@index([organizationId, identifier, channel, purpose])
  @@index([expiresAt])
  @@index([lockedUntil])
}

model UsedOtpSession {
  jti            String   @id
  organizationId String?
  consumedAt     DateTime @default(now())
  expiresAt      DateTime

  @@index([organizationId])
  @@index([expiresAt])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  ACCOUNTANT
  EMPLOYEE
  CLIENT
}

enum UserGender {
  MALE
  FEMALE
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  isSuperAdmin        Boolean              @default(false)
  passwordHash        String
  name                String
  phone               String?
  gender              UserGender?
  avatarUrl           String?
  isActive            Boolean              @default(true)
  role                UserRole             @default(RECEPTIONIST)
  customRoleId        String?
  customRole          CustomRole?          @relation(fields: [customRoleId], references: [id])
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([isSuperAdmin])
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  tokenHash      String    @unique
  // First 8 chars of the raw UUID used as a fast lookup key.
  // Lets us do an indexed DB lookup to a single row before the bcrypt compare,
  // avoiding a full-table scan over all active tokens.
  tokenSelector  String
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([tokenSelector])
  @@index([organizationId])
}

model PasswordResetToken {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique
  // First 8 chars of the raw token used as a fast lookup key — mirrors RefreshToken.tokenSelector.
  // Lets us do an indexed DB lookup before the bcrypt/sha256 compare, avoiding scans.
  tokenSelector String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([tokenSelector])
  @@index([userId])
  @@index([expiresAt])
}

model ClientRefreshToken {
  id             String    @id @default(uuid())
  organizationId String
  clientId       String
  tokenHash      String    @unique
  tokenSelector  String
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([clientId])
  @@index([tokenSelector])
  @@index([organizationId])
}

model CustomRole {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  permissions    Permission[]
  users          User[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id             String     @id @default(uuid())
  customRoleId   String
  customRole     CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  // Denormalized from CustomRole — Prisma scoping extension cannot traverse joins.
  organizationId String
  action         String
  subject        String
  createdAt      DateTime   @default(now())

  @@unique([customRoleId, action, subject])
  @@index([organizationId])
}
