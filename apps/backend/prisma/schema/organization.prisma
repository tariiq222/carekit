// Organization BC — branches, services, business-hours, holidays,
// branding-config, intake-forms, ratings. Phase 5 (p5-t*).

// ─── Branches ────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  nameAr    String
  nameEn    String?
  phone     String?
  addressAr String?
  addressEn String?
  city      String?
  country   String   @default("SA")
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessHours BusinessHour[]
  holidays      Holiday[]

  @@index([tenantId])
}

// ─── Departments ─────────────────────────────────────────────────────────────

// isVisible = false → يُخفى القسم في الواجهة وتُعرض فئاته مباشرة تحت الجذر.
model Department {
  id        String   @id @default(uuid())
  tenantId  String
  nameAr    String
  nameEn    String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories ServiceCategory[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ─── Service Categories ──────────────────────────────────────────────────────

// departmentId nullable لدعم فئات بلا قسم (hierarchy مسطح).
model ServiceCategory {
  id           String      @id @default(uuid())
  tenantId     String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  nameAr       String
  nameEn       String?
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  services Service[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([departmentId])
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id            String           @id @default(uuid())
  tenantId      String
  categoryId    String?
  category      ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  nameAr        String
  nameEn        String?
  descriptionAr String?
  descriptionEn String?
  durationMins  Int
  price         Decimal          @db.Decimal(12, 2)
  currency      String           @default("SAR")
  imageUrl      String?
  isActive      Boolean          @default(true)
  archivedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  durationOptions ServiceDurationOption[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([categoryId])
}

// ─── Service Duration Options ────────────────────────────────────────────────

// Per-service duration/price variants. bookingType nullable = applies to all
// booking types; set to a specific BookingType to scope the option to that
// flow (e.g. different durations for GROUP vs INDIVIDUAL of the same service).
// BookingType enum is defined in bookings.prisma — shared across BCs.
model ServiceDurationOption {
  id           String       @id @default(uuid())
  tenantId     String
  serviceId    String
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookingType  BookingType?
  label        String
  labelAr      String
  durationMins Int
  price        Decimal      @db.Decimal(12, 2)
  currency     String       @default("SAR")
  isDefault    Boolean      @default(false)
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
  @@index([serviceId])
  @@index([serviceId, bookingType])
}

// ─── Business Hours ──────────────────────────────────────────────────────────

// dayOfWeek: 0=Sunday … 6=Saturday
model BusinessHour {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String   // "HH:mm"
  endTime   String   // "HH:mm"
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, dayOfWeek])
  @@index([tenantId])
  @@index([branchId])
}

// ─── Holidays ────────────────────────────────────────────────────────────────

model Holiday {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  nameAr    String
  nameEn    String?
  createdAt DateTime @default(now())

  @@unique([branchId, date])
  @@index([tenantId])
  @@index([branchId])
}

// ─── Branding Config ─────────────────────────────────────────────────────────

model BrandingConfig {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  clinicNameAr  String
  clinicNameEn  String?
  logoUrl       String?
  faviconUrl    String?
  primaryColor  String?
  accentColor   String?
  fontFamily    String?
  customCss     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

// ─── Intake Forms ─────────────────────────────────────────────────────────────

enum IntakeFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
  RADIO
}

model IntakeForm {
  id        String        @id @default(uuid())
  tenantId  String
  nameAr    String
  nameEn    String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  fields    IntakeField[]

  @@index([tenantId])
}

model IntakeField {
  id           String          @id @default(uuid())
  tenantId     String
  formId       String
  form         IntakeForm      @relation(fields: [formId], references: [id], onDelete: Cascade)
  labelAr      String
  labelEn      String?
  fieldType    IntakeFieldType
  isRequired   Boolean         @default(false)
  options      Json?           // string[] for SELECT/RADIO/CHECKBOX
  position     Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
  @@index([formId])
}

// ─── Ratings ──────────────────────────────────────────────────────────────────

model Rating {
  id          String   @id @default(uuid())
  tenantId    String
  bookingId   String   @unique // one rating per booking
  clientId    String
  employeeId  String
  score       Int      // 1–5
  comment     String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId])
  @@index([clientId])
}
