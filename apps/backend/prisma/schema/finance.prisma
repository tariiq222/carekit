// Finance BC — invoices, payments, coupons, gift cards, ZATCA submissions.
// Models added in Phase 7 (p7-t*). Finance BC number in kanban: p6 (column 7).

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  VOID
  REFUNDED
}

enum PaymentMethod {
  ONLINE_CARD
  BANK_TRANSFER
  CASH
  GIFT_CARD
  COUPON
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  COMPLETED
  FAILED
  REFUNDED
}

enum ZatcaSubmissionStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Invoice ─────────────────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  branchId     String
  clientId     String
  employeeId   String
  bookingId    String        @unique
  subtotal     Decimal       @db.Decimal(12, 2)
  discountAmt  Decimal       @default(0) @db.Decimal(12, 2)
  vatRate      Decimal       @default(0.15) @db.Decimal(5, 4)
  vatAmt       Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  currency     String        @default("SAR")
  status       InvoiceStatus @default(DRAFT)
  issuedAt     DateTime?
  dueAt        DateTime?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments     Payment[]
  zatcaSub     ZatcaSubmission?

  @@index([tenantId])
  @@index([clientId])
  @@index([bookingId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  tenantId        String
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("SAR")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  gatewayRef      String?       // Moyasar payment id
  idempotencyKey  String?       @unique // prevent duplicate webhook processing
  receiptUrl      String?       // MinIO path for bank transfer receipt
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([invoiceId])
  @@index([gatewayRef])
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(uuid())
  tenantId       String
  code           String
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  minOrderAmt    Decimal?     @db.Decimal(12, 2)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions    CouponRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model CouponRedemption {
  id        String   @id @default(uuid())
  tenantId  String
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  invoiceId String
  clientId  String
  discount  Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())

  @@unique([couponId, invoiceId])
  @@index([tenantId])
  @@index([invoiceId])
}

// ─── Gift Card ────────────────────────────────────────────────────────────────

model GiftCard {
  id            String   @id @default(uuid())
  tenantId      String
  code          String
  initialBalance Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  currency      String   @default("SAR")
  recipientName  String?
  recipientEmail String?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions   GiftCardRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model GiftCardRedemption {
  id         String   @id @default(uuid())
  tenantId   String
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  invoiceId  String
  clientId   String
  amount     Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())

  @@index([tenantId])
  @@index([invoiceId])
  @@index([giftCardId])
}

// ─── ZATCA Submission ─────────────────────────────────────────────────────────

model ZatcaSubmission {
  id         String                @id @default(uuid())
  tenantId   String
  invoiceId  String                @unique
  invoice    Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  status     ZatcaSubmissionStatus @default(PENDING)
  zatcaUuid  String?
  qrCode     String?
  xmlHash    String?
  submittedAt DateTime?
  responseRaw Json?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([tenantId])
}
