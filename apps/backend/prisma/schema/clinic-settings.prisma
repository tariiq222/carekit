model ClinicSettings {
  id                    String   @id @default(uuid())
  companyNameAr         String?  @map("company_name_ar")
  companyNameEn         String?  @map("company_name_en")
  businessRegistration  String?  @map("business_registration")
  vatRegistrationNumber String?  @map("vat_registration_number")
  vatRate               Decimal  @default(15) @map("vat_rate")
  sellerAddress         String?  @map("seller_address")
  clinicCity            String   @default("الرياض") @map("clinic_city")
  postalCode            String?  @map("postal_code")
  contactPhone          String?  @map("contact_phone")
  contactEmail          String?  @map("contact_email")
  address               String?
  socialMedia           Json?    @map("social_media")
  aboutAr               String?  @map("about_ar") @db.Text
  aboutEn               String?  @map("about_en") @db.Text
  privacyPolicyAr       String?  @map("privacy_policy_ar") @db.Text
  privacyPolicyEn       String?  @map("privacy_policy_en") @db.Text
  termsAr               String?  @map("terms_ar") @db.Text
  termsEn               String?  @map("terms_en") @db.Text
  cancellationPolicyAr  String?  @map("cancellation_policy_ar") @db.Text
  cancellationPolicyEn  String?  @map("cancellation_policy_en") @db.Text
  defaultLanguage       String   @default("ar") @map("default_language")
  timezone              String   @default("Asia/Riyadh")
  weekStartDay          String   @default("sunday") @map("week_start_day")
  dateFormat            String   @default("Y-m-d") @map("date_format")
  timeFormat            String   @default("24h") @map("time_format")
  emailHeaderShowLogo   Boolean  @default(true) @map("email_header_show_logo")
  emailHeaderShowName   Boolean  @default(true) @map("email_header_show_name")
  emailFooterPhone      String?  @map("email_footer_phone")
  emailFooterWebsite    String?  @map("email_footer_website")
  emailFooterInstagram  String?  @map("email_footer_instagram")
  emailFooterTwitter    String?  @map("email_footer_twitter")
  emailFooterSnapchat   String?  @map("email_footer_snapchat")
  emailFooterTiktok     String?  @map("email_footer_tiktok")
  emailFooterLinkedin   String?  @map("email_footer_linkedin")
  emailFooterYoutube    String?  @map("email_footer_youtube")
  sessionDuration       Int      @default(30) @map("session_duration")
  reminderBeforeMinutes Int      @default(60) @map("reminder_before_minutes")
  theme                 Json?    // ClinicTheme — null = DEFAULT_THEME
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("clinic_settings")
}

model ClinicIntegrations {
  id                    String   @id @default(uuid())
  moyasarPublishableKey String?  @map("moyasar_publishable_key")
  moyasarSecretKey      String?  @map("moyasar_secret_key")
  bankName              String?  @map("bank_name")
  bankIban              String?  @map("bank_iban")
  bankAccountHolder     String?  @map("bank_account_holder")
  zoomClientId          String?  @map("zoom_client_id")
  zoomClientSecret      String?  @map("zoom_client_secret")
  zoomAccountId         String?  @map("zoom_account_id")
  emailProvider         String?  @map("email_provider")
  emailApiKey           String?  @map("email_api_key")
  emailFrom             String?  @map("email_from")
  openrouterApiKey      String?  @map("openrouter_api_key")
  firebaseConfig        Json?    @map("firebase_config")
  zatcaPhase            String   @default("phase1") @map("zatca_phase")
  zatcaCsid             String?  @map("zatca_csid")
  zatcaSecret           String?  @map("zatca_secret")
  zatcaPrivateKey       String?  @map("zatca_private_key")
  zatcaRequestId        String?  @map("zatca_request_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("clinic_integrations")
}
