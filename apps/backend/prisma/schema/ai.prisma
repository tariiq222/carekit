// AI BC — knowledge base, embeddings (pgvector), RAG chat sessions.
// Uses the `vector` type from pgvector declared in main.prisma.

enum DocumentStatus {
  PENDING
  EMBEDDED
  FAILED
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model KnowledgeDocument {
  id          String         @id @default(uuid())
  tenantId    String
  title       String
  sourceType  String         // "manual" | "url" | "file"
  sourceRef   String?        // URL or MinIO object key
  status      DocumentStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  chunks      DocumentChunk[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model DocumentChunk {
  id         String   @id @default(uuid())
  tenantId   String
  documentId String
  content    String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())

  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([documentId])
}

// ─── Chat Sessions ────────────────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String?
  userId    String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@index([tenantId, createdAt])
  @@index([tenantId, clientId])
}

// ─── Chatbot Config ───────────────────────────────────────────────────────────

model ChatbotConfig {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, category])
}

model ChatMessage {
  id          String   @id @default(uuid())
  sessionId   String
  role        String   // "user" | "assistant" | "system"
  content     String
  tokensUsed  Int      @default(0)
  model       String?
  createdAt   DateTime @default(now())

  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
