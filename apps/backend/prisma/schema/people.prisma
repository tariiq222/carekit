// People BC — clients, employees, availability, onboarding.
// Models added in Phase 4 (p4-t*).

// Gender is redeclared here independently — no cross-BC Prisma relations.
// The generated enum name is `ClientGender` to avoid collision with `UserGender`.
enum ClientGender {
  MALE
  FEMALE
}

enum ClientSource {
  WALK_IN
  ONLINE
  REFERRAL
}

model Client {
  id          String        @id @default(uuid())
  tenantId    String
  userId      String?
  name        String
  phone       String?
  email       String?
  gender      ClientGender?
  dateOfBirth DateTime?
  avatarUrl   String?
  notes       String?
  source      ClientSource  @default(WALK_IN)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([userId])
}

enum EmployeeGender {
  MALE
  FEMALE
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

// Cross-BC IDs (specialtyId, branchId, serviceId) are plain strings —
// no Prisma FK relations to Clinic BC. Referential integrity is event-driven.
model Employee {
  id             String         @id @default(uuid())
  tenantId       String
  userId         String?
  name           String
  nameEn         String?
  nameAr         String?
  title          String?
  specialty      String?
  specialtyAr    String?
  phone          String?
  email          String?
  gender         EmployeeGender?
  avatarUrl      String?
  bio            String?
  bioAr          String?
  education      String?
  educationAr    String?
  experience     Int?
  employmentType   EmploymentType   @default(FULL_TIME)
  onboardingStatus OnboardingStatus @default(PENDING)
  isActive         Boolean          @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  specialties    EmployeeSpecialty[]
  branches       EmployeeBranch[]
  services       EmployeeService[]
  availability   EmployeeAvailability[]
  exceptions     EmployeeAvailabilityException[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([userId])
}

model EmployeeSpecialty {
  id           String   @id @default(uuid())
  tenantId     String
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  specialtyId  String

  @@unique([employeeId, specialtyId])
  @@index([tenantId])
  @@index([employeeId])
}

model EmployeeBranch {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId   String

  @@unique([employeeId, branchId])
  @@index([tenantId])
  @@index([employeeId])
}

model EmployeeService {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  serviceId  String

  @@unique([employeeId, serviceId])
  @@index([tenantId])
  @@index([employeeId])
}

// Multiple rows per (employeeId, dayOfWeek) represent split shifts
// (e.g. 09:00-13:00 then 16:00-21:00). The gap between shifts IS the break.
// A missing dayOfWeek row = weekly off day.
model EmployeeAvailability {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId, dayOfWeek])
}

// Date-range exception — employee is off from startDate to endDate (inclusive).
// Single-day leave: startDate == endDate. Annual leave: multi-day range.
// No partial-day overrides — adjust EmployeeAvailability instead.
model EmployeeAvailabilityException {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  reason     String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId, startDate, endDate])
}
