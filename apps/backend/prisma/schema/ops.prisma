// Ops BC — activity log, scheduled jobs, generated reports, health.
// Models added in Phase 10 (p10-t*).

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  SYSTEM
}

enum ReportType {
  REVENUE
  ACTIVITY
  BOOKINGS
  EMPLOYEES
}

enum ReportFormat {
  JSON
  EXCEL
}

enum ReportStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── ActivityLog ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String         @id @default(uuid())
  userId      String?
  userEmail   String?
  action      ActivityAction
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime       @default(now())

  @@index([occurredAt])
  @@index([entity, entityId])
  @@index([userId])
}

// ─── Report ──────────────────────────────────────────────────────────────────

model Report {
  id          String       @id @default(uuid())
  type        ReportType
  format      ReportFormat @default(JSON)
  status      ReportStatus @default(PENDING)
  params      Json
  resultUrl   String?
  resultData  Json?
  errorMsg    String?
  requestedBy String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([type, createdAt])
}
