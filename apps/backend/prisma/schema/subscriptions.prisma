// Finance BC — Subscription packages.
// Subscriptions allow clients to purchase plans with benefits like discounts or session credits.

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum SubscriptionBenefitType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  SESSION_CREDITS
  FREE_SESSIONS
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  branchId       String
  nameAr         String
  nameEn         String
  descriptionAr  String?
  descriptionEn  String?
  price          Decimal  @db.Decimal(12, 2)
  currency       String   @default("SAR")
  durationDays   Int      @default(30)
  benefits       Json     @default("[]")
  isPublic       Boolean  @default(false)
  isActive       Boolean  @default(true)
  maxUsage       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientSubscriptions ClientSubscription[]

  @@index([branchId])
  @@index([isPublic])
}

model ClientSubscription {
  id                String             @id @default(uuid())
  clientId          String
  planId            String
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  status            SubscriptionStatus @default(PENDING)
  benefitsUsed      Int                @default(0)
  maxBenefits       Int?
  startDate         DateTime?
  endDate           DateTime?
  totalPaid         Decimal            @default(0) @db.Decimal(12, 2)
  invoiceId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([clientId])
  @@index([planId])
  @@index([status])
}