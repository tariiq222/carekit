# =============================================================================
# CareKit — Production Environment Template
# =============================================================================
# Copy to .env.prod, fill every value, then run:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
#
# The backend's Joi validator (apps/backend/src/config/env.validation.ts) will
# refuse to boot if any required key is missing or contains a dev placeholder
# (`change-me`, `dev-`, `sk_test_`, `CHANGE_ME`). Generate real values below.
#
# SAFETY:
# - Never commit .env.prod (already in .gitignore).
# - Rotate JWT/encryption keys at least every 12 months.
# - Use a secrets manager (1Password / Vault / AWS SM) — these env files are
#   for bootstrapping only.
# =============================================================================

NODE_ENV=production
PORT=5100

# -----------------------------------------------------------------------------
# Domain / URLs (REQUIRED, must be HTTPS in production)
# -----------------------------------------------------------------------------
# Backend public URL
BACKEND_URL=https://api.carekit.app

# Per-tenant clinic dashboard
DASHBOARD_PUBLIC_URL=https://app.carekit.app

# Public marketing/info site (used in email links + payment redirect URLs)
PUBLIC_WEBSITE_URL=https://carekit.app

# Comma-separated allowed origins for CORS. NO trailing slashes.
# Include every frontend that will call the backend.
CORS_ORIGINS=https://app.carekit.app,https://admin.carekit.app,https://carekit.app

# Admin Host Allow-list — AdminHostGuard rejects any other Host header.
# Comma-separated. Include both the public host and any internal proxy hosts.
ADMIN_HOSTS=admin.carekit.app

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# Generate strong values:
#   POSTGRES_PASSWORD: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
POSTGRES_USER=carekit
POSTGRES_PASSWORD=REPLACE_WITH_32_CHAR_RANDOM
POSTGRES_DB=carekit_prod

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------
# Generate:
#   REDIS_PASSWORD: openssl rand -base64 24 | tr -d '/+='
REDIS_PASSWORD=REPLACE_WITH_24_CHAR_RANDOM

# -----------------------------------------------------------------------------
# MinIO / Object Storage (REQUIRED)
# -----------------------------------------------------------------------------
# Generate:
#   MINIO_ACCESS_KEY: openssl rand -hex 16
#   MINIO_SECRET_KEY: openssl rand -base64 32 | tr -d '/+='
MINIO_ACCESS_KEY=REPLACE_WITH_HEX_16
MINIO_SECRET_KEY=REPLACE_WITH_BASE64_32
MINIO_BUCKET=carekit
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# JWT — Identity (REQUIRED, all 5 secrets must be DISTINCT)
# -----------------------------------------------------------------------------
# Generate each one INDEPENDENTLY (do NOT reuse across keys):
#   for k in JWT_ACCESS_SECRET JWT_REFRESH_SECRET JWT_OTP_SECRET JWT_CLIENT_ACCESS_SECRET; do
#     echo "$k=$(openssl rand -base64 48 | tr -d '/+=' | cut -c1-48)"
#   done
JWT_ACCESS_SECRET=REPLACE_WITH_48_CHAR_RANDOM
JWT_REFRESH_SECRET=REPLACE_WITH_48_CHAR_RANDOM
JWT_OTP_SECRET=REPLACE_WITH_48_CHAR_RANDOM
JWT_CLIENT_ACCESS_SECRET=REPLACE_WITH_48_CHAR_RANDOM

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_CLIENT_ACCESS_TTL=7d
JWT_CLIENT_REFRESH_TTL=30d

# -----------------------------------------------------------------------------
# Per-tenant encryption keys (REQUIRED — base64-encoded 32 bytes, length 44)
# -----------------------------------------------------------------------------
# Used to AES-256-GCM encrypt SMS provider credentials and Zoom credentials
# stored per organization. organizationId is the AAD — a DB dump alone cannot
# decrypt under a different tenant.
#
# Generate each:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SMS_PROVIDER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES_LEN_44=
ZOOM_PROVIDER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES_LEN_44=

# Public origin where SMS providers (Unifonic/Taqnyat) POST DLR webhooks.
SMS_WEBHOOK_URL_BASE=https://api.carekit.app

# -----------------------------------------------------------------------------
# Multi-tenancy (REQUIRED)
# -----------------------------------------------------------------------------
# 'strict' is the platform default. Production refuses anything else at boot.
TENANT_ENFORCEMENT=strict
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Authentica (REQUIRED — platform OTP for mobile/website login)
# -----------------------------------------------------------------------------
# Get from: https://portal.authentica.sa/settings/apikeys/
# This is DISTINCT from per-tenant SMS providers (Unifonic/Taqnyat) — Authentica
# delivers OTP codes for client login, the per-tenant providers send booking SMS.
AUTHENTICA_API_KEY=REPLACE_WITH_AUTHENTICA_API_KEY
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# -----------------------------------------------------------------------------
# CAPTCHA (REQUIRED — bot protection on auth/OTP endpoints)
# -----------------------------------------------------------------------------
# Provider: 'hcaptcha' or 'turnstile'. 'noop' is dev-only and rejected in prod.
# Get from: https://dashboard.hcaptcha.com/sites
CAPTCHA_PROVIDER=hcaptcha
HCAPTCHA_SECRET=REPLACE_WITH_HCAPTCHA_SECRET

# -----------------------------------------------------------------------------
# Sentry (RECOMMENDED — error tracking)
# -----------------------------------------------------------------------------
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
# Leave empty to silently disable (NOT recommended in production).
SENTRY_DSN=

# -----------------------------------------------------------------------------
# SMTP — transactional email (REQUIRED for booking confirmations etc.)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@carekit.app

# -----------------------------------------------------------------------------
# FCM — Firebase Cloud Messaging (REQUIRED for mobile push notifications)
# -----------------------------------------------------------------------------
# Get from: Firebase Console > Project Settings > Service Accounts > Generate Key
# Paste the private key WITH literal \n separators preserved (not real newlines).
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# AI — OpenAI (embeddings) + OpenRouter (chat) — required if chatbot enabled
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku

# -----------------------------------------------------------------------------
# Tenant Moyasar (per-tenant — receives clinic booking payments)
# -----------------------------------------------------------------------------
# These are the FALLBACK keys used when an organization has no
# OrganizationPaymentConfig row. Each tenant should configure their own keys
# via /settings/payments. Leave empty if you require all tenants to self-configure.
MOYASAR_API_KEY=
MOYASAR_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Platform Moyasar (SaaS-04 — charges CLINICS for their CareKit subscription)
# -----------------------------------------------------------------------------
# Get from your CareKit Moyasar account (separate from any tenant account).
# Use sk_live_* keys; pk_test_*/sk_test_* will be rejected in production.
MOYASAR_PLATFORM_SECRET_KEY=sk_live_REPLACE_ME
MOYASAR_PLATFORM_WEBHOOK_SECRET=REPLACE_WITH_PLATFORM_WEBHOOK_SECRET
SAAS_TRIAL_DAYS=14
SAAS_GRACE_PERIOD_DAYS=2

# Set to 'true' AFTER first tenant onboarded + you've verified live charge flow.
# Cron tasks that meter usage and charge subscriptions only run when true.
BILLING_CRON_ENABLED=false

# Slug of the Plan row assigned to orgs without an active subscription.
# Must exist in DB before first tenant boots. Format: ^[A-Z][A-Z0-9_]{1,31}$
PLATFORM_DEFAULT_PLAN_SLUG=BASIC

# -----------------------------------------------------------------------------
# Super-admin bootstrap (REQUIRED for first super-admin account)
# -----------------------------------------------------------------------------
# Used by `npm run seed` to create the initial super-admin if none exists.
# Use a real email (recovery + audit log routing).
# Generate password:
#   openssl rand -base64 32 | tr -d '/+=' | cut -c1-24
SUPER_ADMIN_EMAIL=admin@carekit.app
SUPER_ADMIN_PASSWORD=REPLACE_WITH_24_CHAR_RANDOM

# -----------------------------------------------------------------------------
# ZATCA (DISABLED until UBL 2.1 builder is compliance-reviewed)
# -----------------------------------------------------------------------------
# Setting ZATCA_ENABLED=true with a stub XML will cause every invoice to be
# rejected by ZATCA — keep 'false' until the integration is signed off.
ZATCA_ENABLED=false
ZATCA_API_URL=
ZATCA_API_KEY=

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
# Encryption key for nightly DB + MinIO backups (gpg symmetric).
# Generate: openssl rand -base64 32 | tr -d '/+='
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32

# -----------------------------------------------------------------------------
# Frontend public env (used at build-time by dashboard/admin/website)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.carekit.app
